<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="#ffffff">

    <TextView
        android:id="@+id/weightDisplay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Weight: 0.000"
        android:textSize="32sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        android:textColor="#212121"
        android:background="#f5f5f5"/>

    <!-- Row 1: buttons 1-5 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">
        <Button android:id="@+id/btn1" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="1" android:textSize="14sp" android:layout_marginEnd="2dp"/>
        <Button android:id="@+id/btn2" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="2" android:textSize="14sp" android:layout_marginEnd="2dp"/>
        <Button android:id="@+id/btn3" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="3" android:textSize="14sp" android:layout_marginEnd="2dp"/>
        <Button android:id="@+id/btn4" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="4" android:textSize="14sp" android:layout_marginEnd="2dp"/>
        <Button android:id="@+id/btn5" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="5"/>
    </LinearLayout>

    <!-- Row 2: buttons 6-10 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="4dp">
        <Button android:id="@+id/btn6" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="6" android:textSize="14sp" android:layout_marginEnd="2dp"/>
        <Button android:id="@+id/btn7" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="7" android:textSize="14sp" android:layout_marginEnd="2dp"/>
        <Button android:id="@+id/btn8" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="8" android:textSize="14sp" android:layout_marginEnd="2dp"/>
        <Button android:id="@+id/btn9" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="9" android:textSize="14sp" android:layout_marginEnd="2dp"/>
        <Button android:id="@+id/btn10" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="10"/>
    </LinearLayout>

    <!-- Navigation buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">
        <Button
            android:id="@+id/btnWeightScreen"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Weight Screen"
            android:backgroundTint="#4CAF50"
            android:textColor="#ffffff"
            android:layout_marginEnd="4dp"
            android:textSize="12sp"/>
        <Button
            android:id="@+id/btnWeightLive"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Live Weight"
            android:backgroundTint="#2196F3"
            android:textColor="#ffffff"
            android:layout_marginEnd="4dp"
            android:textSize="12sp"/>
        <Button
            android:id="@+id/btnDisconnect"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Disconnect"
            android:backgroundTint="#F44336"
            android:textColor="#ffffff"
            android:textSize="12sp"/>
    </LinearLayout>

    <!-- Weight log -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Weight Log"
        android:textStyle="bold"
        android:textSize="14sp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp"
        android:textColor="#555555"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <ListView
            android:id="@+id/weightLogList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:divider="#eeeeee"
            android:dividerHeight="1dp"/>
    </ScrollView>

</LinearLayout>
